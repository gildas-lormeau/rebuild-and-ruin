{
  "name": "project-castles-99",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test:headless": "bun src/headless-test.ts",
    "test:build-ai": "bun test/build-ai-1x1.test.ts && bun test/build-ai-1x2.test.ts && bun test/build-ai-1x3.test.ts && bun test/build-ai-C.test.ts && bun test/build-ai-J.test.ts && bun test/build-ai-L.test.ts && bun test/build-ai-PLUS.test.ts && bun test/build-ai-S.test.ts && bun test/build-ai-SR.test.ts",
    "test:e2e": "npx tsx test/online-e2e.ts",
    "test:e2e:local": "npx tsx test/online-e2e.ts local 0",
    "test:e2e:local:quick": "npx tsx test/online-e2e.ts local 0 --headless '' 1",
    "test:e2e:mobile": "npx tsx test/online-e2e.ts local 0 --mobile --screenshot",
    "test:all": "npm run test:headless && npm run test:build-ai && npm run test:e2e:local:quick",
    "lint": "biome check src/ server/",
    "lint:fix": "biome check --fix --unsafe src/ server/",
    "lint:unused": "knip",
    "lint:circular": "madge --circular --extensions ts src/ server/",
    "lint:duplicates": "jscpd src/ --min-lines 10",
    "lint:literals": "npm run find-literals",
    "find-literals": "npx tsx scripts/find-duplicate-literals.ts",
    "lint:server": "deno check server/server.ts",
    "lint:layers": "npx tsx scripts/generate-import-layers.ts --check --server",
    "lint:imports": "npx tsx scripts/merge-imports.ts --check",
    "lint:eslint": "eslint src/",
    "lint:all": "npm run lint && npm run lint:eslint && npm run lint:unused && npm run lint:circular && npm run lint:duplicates && npm run lint:literals && npm run lint:layers && npm run lint:imports && npm run lint:server",
    "export-index": "npx tsx scripts/generate-export-index.ts --server",
    "export-search": "npx tsx scripts/generate-export-index.ts --search",
    "hot-exports": "npx tsx scripts/report-hot-exports.ts",
    "reorder": "npx tsx scripts/reorder-file.ts",
    "reorder:changed": "git diff --cached --name-only --diff-filter=ACM -- 'src/*.ts' | xargs -I{} npx tsx scripts/reorder-file.ts {}",
    "readonly-params": "npx tsx scripts/add-readonly-params.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@types/bun": "latest",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "jscpd": "4.0.8",
    "knip": "6.0.3",
    "madge": "8.0.0",
    "playwright": "^1.58.2",
    "ts-morph": "^27.0.2",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vite": "^7.3.1"
  }
}
