{
  "name": "project-castles-99",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test:scenario": "timeout 30 deno test --no-check test/scenario.test.ts",
    "test:catapult": "timeout 60 deno test --no-check test/catapult.test.ts",
    "test:phase": "timeout 60 deno test --no-check test/phase-tests/",
    "fixture:check": "deno run --no-check -A scripts/fixture-check.ts",
    "fixture": "deno run --no-check -A scripts/fixture-cli.ts",
    "fixture:edit": "deno run --no-check -A scripts/fixture-tui.ts",
    "test:determinism": "timeout 30 deno test --no-check --allow-read test/determinism.test.ts",
    "test:speed": "timeout 30 deno test --no-check test/dev-speed.test.ts",
    "test:modifiers": "timeout 60 deno test --no-check test/modifiers.test.ts",
    "test:upgrades": "timeout 60 deno test --no-check test/upgrades.test.ts",
    "test:cannon-tier": "timeout 30 deno test --no-check test/cannon-tier.test.ts",
    "test:input": "timeout 30 deno test --no-check test/input-lobby.test.ts",
    "test:touch": "timeout 30 deno test --no-check test/input-touch.test.ts",
    "test:dpad": "timeout 30 deno test --no-check test/controller-human-dpad.test.ts",
    "test:haptics": "timeout 30 deno test --no-check test/haptics-observer.test.ts",
    "test:network": "timeout 30 deno test --no-check test/network-observer.test.ts",
    "test:network-vs-local": "timeout 120 deno test --no-check test/network-vs-local.test.ts",
    "test:network-bidirectional": "timeout 120 deno test --no-check -A test/network-bidirectional.test.ts",
    "record-determinism": "deno run -A scripts/record-determinism.ts",
    "record-checkpoint": "deno run -A scripts/record-checkpoint.ts",
    "test:online": "timeout 10 deno test --no-check test/online-unit.test.ts",
    "test:relay": "deno test --allow-net test/online-relay.test.ts",
    "test:game-over": "deno test --allow-all test/online-game-over.test.ts",
    "test:e2e": "deno run -A scripts/online-e2e.ts",
    "test:e2e:local": "deno run -A scripts/online-e2e.ts local 0",
    "test:e2e:local:quick": "deno run -A scripts/online-e2e.ts local 0 --headless '' 1",
    "test:e2e:mobile": "deno run -A scripts/online-e2e.ts local 0 --mobile --screenshot",
    "test:e2e:online:coverage:build-start": "deno run -A scripts/online-e2e.ts online 1 \"\" 1 --headless --coverage --action \"phase:WALL_BUILD exit\"",
    "test:e2e:banner-prev-scene": "deno run -A test/e2e-banner-prev-scene.ts",
    "test:dt-divergence": "deno test --no-check test/dt-divergence.test.ts",
    "find-seed": "deno run -A scripts/find-seed.ts",
    "sprite-view": "deno run -A scripts/sprite-view.ts",
    "perf:ai:cpu": "mkdir -p tmp/perf && deno run --cpu-prof --cpu-prof-dir tmp/perf --cpu-prof-name ai-cpu.cpuprofile -A scripts/perf-ai-headless.ts && deno run -A scripts/analyze-cpu.ts tmp/perf/ai-cpu.cpuprofile --filter src/ai/",
    "perf:ai:cpu:multi": "deno run -A scripts/perf-ai-multi.ts",
    "record-seeds": "deno run -A scripts/record-seeds.ts --parallel 4",
    "test:all": "npm run test:scenario && npm run test:determinism && npm run test:speed && npm run test:input && npm run test:touch && npm run test:dpad && npm run test:haptics && npm run test:network && npm run test:network-vs-local && npm run test:online && npm run test:banner && npm run test:modifiers && npm run test:upgrades && npm run test:cannon-tier && npm run test:e2e:local:quick",
    "format": "biome format --write src/ server/",
    "format:check": "biome format src/ server/",
    "lint": "biome check src/ server/",
    "lint:fix": "biome check --fix --unsafe src/ server/",
    "lint:unused": "knip",
    "lint:circular": "madge --circular --extensions ts src/ server/",
    "lint:duplicates": "jscpd src/ --min-lines 10",
    "lint:guards": "deno run -A scripts/lint-useless-guards.ts",
    "lint:if-chain": "deno run -A scripts/lint-if-chain.ts",
    "lint:passthrough": "deno run -A scripts/lint-passthrough-wrappers.ts",
    "lint:helper-reuse": "deno run -A scripts/lint-helper-reuse.ts",
    "lint:modifier-lifecycle": "deno run -A scripts/lint-modifier-lifecycle.ts",
    "lint:monotone-state": "deno run -A scripts/lint-monotone-state.ts",
    "lint:internal-jsdoc": "deno run -A scripts/lint-internal-jsdoc.ts",
    "lint:shapes": "deno run -A scripts/find-shape-duplicates.ts --exact-only --test",
    "lint:shapes:audit": "deno run -A scripts/find-shape-duplicates.ts --test",
    "lint:literals": "npm run find-literals",
    "find-literals": "deno run -A scripts/find-duplicate-literals.ts",
    "lint:deno": "deno check --quiet src server/ test/",
    "lint:deno-lint": "deno lint src test/ server/",
    "lint:layers": "deno run -A scripts/generate-import-layers.ts --check",
    "lint:lateral": "deno run -A scripts/lint-lateral-imports.ts",
    "lint:imports": "deno run -A scripts/merge-imports.ts --check",
    "lint:architecture": "deno run -A scripts/lint-architecture.ts",
    "lint:architecture:non-runtime": "deno run -A scripts/lint-architecture-non-runtime.ts",
    "lint:restricted": "deno run -A scripts/lint-restricted-imports.ts",
    "lint:phase-transitions": "deno run -A scripts/lint-phase-transitions.ts",
    "lint:domains": "deno run -A scripts/lint-domain-boundaries.ts",
    "lint:typeof": "deno run -A scripts/lint-typeof.ts",
    "lint:repeated-ternary": "deno run -A scripts/lint-repeated-ternary.ts",
    "lint:closure-captures": "deno run -A scripts/lint-closure-captures.ts",
    "lint:null-init": "deno run -A scripts/lint-null-init.ts",
    "lint:eslint": "eslint src/",
    "lint:registries": "deno run -A scripts/lint-registries.ts",
    "lint:entry-placement": "deno run -A scripts/lint-entry-placement.ts",
    "lint:checkpoint-fields": "deno run -A scripts/lint-checkpoint-fields.ts",
    "lint:applyat": "deno run -A scripts/lint-applyat.ts",
    "lint:test-timeouts": "deno run -A scripts/lint-test-timeouts.ts",
    "lint:raw-playwright": "deno run -A scripts/lint-raw-playwright.ts",
    "lint:unused-iface": "deno run -A scripts/lint-unused-interface-fields.ts",
    "lint:unused-iface:suggest": "deno run -A scripts/lint-unused-interface-fields.ts --suggest-targets",
    "lint:all": "bash scripts/lint-all.sh",
    "export-index": "deno run -A scripts/generate-export-index.ts --server",
    "export-map": "deno run -A scripts/generate-export-map.ts",
    "export-search": "deno run -A scripts/generate-export-index.ts --search",
    "hot-exports": "deno run -A scripts/report-hot-exports.ts",
    "reorder": "deno run -A scripts/reorder-file.ts",
    "reorder:changed": "git diff --cached --name-only --diff-filter=ACM -- 'src/*.ts' | xargs -I{} deno run -A scripts/reorder-file.ts {}",
    "refactor": "deno run -A scripts/refactor.ts",
    "refactor2": "deno run -A scripts/refactor2/refactor2.ts",
    "audit:optional": "deno run -A scripts/audit-optional-properties.ts",
    "audit:bool-narrow": "deno run -A scripts/audit-boolean-narrowing.ts",
    "audit:brands": "deno run -A scripts/audit-brand-candidates.ts",
    "audit:union-members": "deno run -A scripts/audit-union-members.ts",
    "audit:redundant-casts": "deno run -A scripts/audit-redundant-casts.ts",
    "audit:no-op-writes": "deno run -A scripts/audit-no-op-writes.ts",
    "audit:stale-snapshot": "deno run -A scripts/audit-stale-snapshot.ts",
    "audit:array-drift": "deno run -A scripts/audit-array-element-drift.ts",
    "audit:loose-params": "deno run -A scripts/audit-loose-params.ts",
    "audit:passthrough": "deno run -A scripts/audit-passthrough-functions.ts",
    "audit:single-call-exports": "deno run -A scripts/audit-single-call-exports.ts",
    "audit:nested-same-guard": "deno run -A scripts/audit-nested-same-guard.ts",
    "graph": "deno run -A scripts/layer-graph.ts",
    "graph:files": "deno run -A scripts/file-graph.ts --layout fdp"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^25.9.1",
    "@types/three": "^0.160.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^10.4.0",
    "jscpd": "^4.2.3",
    "knip": "^6.14.2",
    "madge": "8.0.0",
    "playwright": "^1.60.0",
    "ts-morph": "^28.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  },
  "dependencies": {
    "fflate": "^0.8.3",
    "libadlmidi-js": "^2.0.0",
    "qrcode-generator": "^2.0.4",
    "three": "^0.160.1"
  }
}
